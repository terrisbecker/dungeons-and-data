{
  "name": "dungeons-and-data",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack D&D manager — Express/Prisma API + Next.js web",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w @dnd/api",
    "dev:web": "npm run dev -w @dnd/web",
    "build": "npm run build -w @dnd/api && npm run build -w @dnd/web",
    "lint": "npm run lint -w @dnd/api && npm run lint -w @dnd/web",
    "format": "prettier --write .",
    "prisma:generate": "npm run prisma:generate -w @dnd/api",
    "prisma:migrate": "npm run prisma:migrate -w @dnd/api",
    "seed": "npm run seed -w @dnd/api"
  },
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.9.5"
  }
}
