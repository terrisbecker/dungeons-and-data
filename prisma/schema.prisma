generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums — the fixed sets defined by the 5e rules. Free-text is kept elsewhere
// (race, className, item/condition names) so homebrew stays open; these are
// closed sets where validation and derived math (e.g. skill -> ability) matter.
// ---------------------------------------------------------------------------
enum Ability {
  STR
  DEX
  CON
  INT
  WIS
  CHA
}

enum Alignment {
  LG // Lawful Good
  NG // Neutral Good
  CG // Chaotic Good
  LN // Lawful Neutral
  TN // True Neutral
  CN // Chaotic Neutral
  LE // Lawful Evil
  NE // Neutral Evil
  CE // Chaotic Evil
}

enum Skill {
  ACROBATICS // DEX
  ANIMAL_HANDLING // WIS
  ARCANA // INT
  ATHLETICS // STR
  DECEPTION // CHA
  HISTORY // INT
  INSIGHT // WIS
  INTIMIDATION // CHA
  INVESTIGATION // INT
  MEDICINE // WIS
  NATURE // INT
  PERCEPTION // WIS
  PERFORMANCE // CHA
  PERSUASION // CHA
  RELIGION // INT
  SLEIGHT_OF_HAND // DEX
  STEALTH // DEX
  SURVIVAL // WIS
}

enum SkillProficiency {
  PROFICIENT
  EXPERTISE
  HALF // Jack of All Trades / Remarkable Athlete
}

enum SpellSchool {
  ABJURATION
  CONJURATION
  DIVINATION
  ENCHANTMENT
  EVOCATION
  ILLUSION
  NECROMANCY
  TRANSMUTATION
}

enum FeatureSource {
  RACE
  CLASS
  SUBCLASS
  BACKGROUND
  FEAT
}

enum RestType {
  SHORT
  LONG
  OTHER // e.g. dawn, per-turn, recharge X-Y
}

enum CreatureSize {
  TINY
  SMALL
  MEDIUM
  LARGE
  HUGE
  GARGANTUAN
}

// --- Item catalog enums --------------------------------------------------
// Broad bucket for a catalog item. Weapon/armor sub-details live in the
// *Category fields below. Kept as a closed set; use OTHER + tags for oddities.
enum ItemType {
  ADVENTURING_GEAR
  WEAPON
  ARMOR // includes shields (see ArmorCategory.SHIELD)
  AMMUNITION
  POTION
  SCROLL
  WAND
  ROD
  STAFF
  RING
  WONDROUS_ITEM
  TOOL
  FOOD_AND_DRINK
  TRADE_GOOD
  CONTAINER
  MOUNT_OR_VEHICLE
  TREASURE
  OTHER
}

// 5e magic-item rarity. Mundane gear is COMMON.
enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  VERY_RARE
  LEGENDARY
  ARTIFACT
}

enum WeaponCategory {
  SIMPLE
  MARTIAL
}

enum WeaponProperty {
  AMMUNITION
  FINESSE
  HEAVY
  LIGHT
  LOADING
  RANGE
  REACH
  SPECIAL
  THROWN
  TWO_HANDED
  VERSATILE
}

enum ArmorCategory {
  LIGHT
  MEDIUM
  HEAVY
  SHIELD
}

enum DamageType {
  ACID
  BLUDGEONING
  COLD
  FIRE
  FORCE
  LIGHTNING
  NECROTIC
  PIERCING
  POISON
  PSYCHIC
  RADIANT
  SLASHING
  THUNDER
}

// --- Creature (NPC / Monster) enums --------------------------------------
// NPCs and monsters share an identical stat block, so they are one `Creature`
// table discriminated by `kind`. See the Creature model below.
enum CreatureKind {
  NPC
  MONSTER
}

// The 5e creature types. Homebrew/parenthetical subtypes ("goblinoid",
// "shapechanger") stay free-text on `Creature.typeTags`.
enum CreatureType {
  ABERRATION
  BEAST
  CELESTIAL
  CONSTRUCT
  DRAGON
  ELEMENTAL
  FEY
  FIEND
  GIANT
  HUMANOID
  MONSTROSITY
  OOZE
  PLANT
  UNDEAD
}

// One enum drives a single polymorphic StatBlockEntry table (traits, actions,
// legendary/lair actions, etc.) instead of a table per section.
enum StatBlockEntryCategory {
  TRAIT
  ACTION
  BONUS_ACTION
  REACTION
  LEGENDARY_ACTION
  MYTHIC_ACTION
  LAIR_ACTION
  REGIONAL_EFFECT
}

enum DamageModifierKind {
  VULNERABILITY
  RESISTANCE
  IMMUNITY
}

// ---------------------------------------------------------------------------
// Location
// Locations nest via a
// self-referencing parent/children relation (a region contains hamlets, a
// town contains buildings, etc.).
// ---------------------------------------------------------------------------
model Location {
  id           String  @id @default(uuid()) @db.Uuid
  locationName String
  description  String?
  type         String // free text: region, country, city, town, cottage, ...

  // Nested-location hierarchy (self relation)
  parentId String?    @db.Uuid
  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children Location[] @relation("LocationHierarchy")

  // Occupants — an explicit join model so each assignment can carry its own data.
  creaturePlacements CreaturePlacement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

// ---------------------------------------------------------------------------
// PlayerCharacter
// Ability scores are modeled as six fixed integer columns; skills live in the
// related CharacterSkill table so proficiency vs. expertise can be expressed.
//
// Ability-score convention: the six columns store FINAL scores (base + racial
// ASI + level ASIs/feats). The service layer owns how a score was built; the DB
// stores the resulting number the rest of the math depends on.
// ---------------------------------------------------------------------------
model PlayerCharacter {
  id            String       @id @default(uuid()) @db.Uuid
  characterName String
  race          String // free text (supports homebrew)
  subrace       String? // e.g. "High Elf"
  alignment     Alignment?
  size          CreatureSize @default(MEDIUM)

  // Class and total level are modeled via the CharacterClass relation.
  // Total level (and therefore proficiency bonus) is derived from the sum of
  // class levels in the service layer — intentionally NOT stored here to avoid
  // drift, same discipline as proficiencyBonus/initiative below.

  // Progression
  experiencePoints Int     @default(0)
  inspiration      Boolean @default(false)

  // Ability scores (final values; see convention note above)
  strength     Int @db.SmallInt
  dexterity    Int @db.SmallInt
  constitution Int @db.SmallInt
  intelligence Int @db.SmallInt
  wisdom       Int @db.SmallInt
  charisma     Int @db.SmallInt

  // Saving-throw proficiencies (which of the six the character is proficient in)
  strengthSaveProf     Boolean @default(false)
  dexteritySaveProf    Boolean @default(false)
  constitutionSaveProf Boolean @default(false)
  intelligenceSaveProf Boolean @default(false)
  wisdomSaveProf       Boolean @default(false)
  charismaSaveProf     Boolean @default(false)

  // Combat.
  // NOTE: proficiencyBonus, initiative, passive scores, spell save DC, and
  // spell attack bonus are intentionally NOT stored — derive them in the
  // service layer to avoid drift.
  maxHitPoints        Int
  currentHitPoints    Int
  temporaryHitPoints  Int @default(0)
  hitPointMaxModifier Int @default(0) // effects that raise/lower max HP
  armorClass          Int
  deathSaveSuccesses  Int @default(0)
  deathSaveFailures   Int @default(0)

  // Movement (feet). Non-walking speeds are optional; null = the race lacks it.
  speed      Int  @default(30)
  flySpeed   Int?
  swimSpeed  Int?
  climbSpeed Int?

  // Senses
  darkvision Int? // range in feet; null = no darkvision

  // Concentration — the spell (if any) the character is currently concentrating
  // on. Plain FK (no relation) to keep the write path simple.
  concentratingOnSpellId String? @db.Uuid

  // Currency (5e coin types)
  copper   Int @default(0)
  silver   Int @default(0)
  electrum Int @default(0)
  gold     Int @default(0)
  platinum Int @default(0)

  description String?
  background  String? // free text; grants proficiencies/features via Feature rows

  // The four 5e roleplay boxes. `traits` holds personality traits; ideals,
  // bonds, and flaws are their own free-text fields on the character sheet.
  traits String?
  ideals String?
  bonds  String?
  flaws  String?

  // Ownership / campaign context (stub FKs — target tables to be defined)
  playerId   String? @db.Uuid
  campaignId String? @db.Uuid

  // Relations
  skills        CharacterSkill[]
  inventory     InventoryItem[]
  classes       CharacterClass[]
  proficiencies Proficiency[]
  spells        CharacterSpell[]
  feats         CharacterFeat[]
  features      CharacterFeature[]
  conditions    CharacterCondition[]
  resources     CharacterResource[]
  spellSlots    SpellSlot[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  @@index([playerId])
  @@index([campaignId])
}

// A class a character has levels in. Multiple rows = multiclassing.
model CharacterClass {
  id          String          @id @default(uuid()) @db.Uuid
  characterId String          @db.Uuid
  character   PlayerCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  className String // "Wizard"
  subclass  String? // "Evocation"
  level     Int     @default(1)

  // Hit dice belong to the class: die size is fixed per class, and multiclass
  // characters have mixed pools. `hitDiceUsed` tracks spend across short rests;
  // the max for this class equals `level`.
  hitDieSize  Int // 6, 8, 10, 12 (a d8 -> 8)
  hitDiceUsed Int @default(0)

  // Spellcasting ability for this class (INT wizard, WIS cleric, CHA bard...).
  // Null for non-casters. Drives spell save DC / attack bonus in the service layer.
  spellcastingAbility Ability?

  @@unique([characterId, className])
}

// Per-level spell slots. Warlock pact magic is a separate track (isPact).
model SpellSlot {
  id          String          @id @default(uuid()) @db.Uuid
  characterId String          @db.Uuid
  character   PlayerCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  level  Int // 1–9
  max    Int
  used   Int     @default(0)
  isPact Boolean @default(false) // Warlock pact magic slots

  @@unique([characterId, level, isPact])
}

// Limited-use pools: Rage, Ki, Channel Divinity, Bardic Inspiration, Sorcery
// Points, Superiority Dice, Lay on Hands, etc. One flexible row per feature.
model CharacterResource {
  id          String          @id @default(uuid()) @db.Uuid
  characterId String          @db.Uuid
  character   PlayerCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  name       String // "Rage", "Ki Points", "Channel Divinity"
  current    Int
  max        Int
  rechargeOn RestType @default(LONG)

  @@unique([characterId, name])
}

// Weapon / armor / tool / language / saving-throw proficiencies.
model Proficiency {
  id          String          @id @default(uuid()) @db.Uuid
  characterId String          @db.Uuid
  character   PlayerCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  type String // "weapon" | "armor" | "tool" | "language" | "save"
  name String // "Longsword", "Thieves' Tools", "Elvish", ...

  @@unique([characterId, type, name])
}

// A single skill proficiency held by a character. Absence = not proficient.
model CharacterSkill {
  id          String          @id @default(uuid()) @db.Uuid
  characterId String          @db.Uuid
  character   PlayerCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  skill       Skill
  proficiency SkillProficiency @default(PROFICIENT)

  @@unique([characterId, skill])
}

// ---------------------------------------------------------------------------
// Stub tables — created so the relations above have real foreign keys.
// Expand these as the items/economy and NPC/monster specs are fleshed out.
// ---------------------------------------------------------------------------
// Catalog definition of an item — created ONCE and shared. Ownership and
// per-instance state live in InventoryItem, so a single "Shortsword" row can be
// assigned to any number of characters, NPCs, shops, or chests.
model Item {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?

  // Classification
  type    ItemType   @default(ADVENTURING_GEAR)
  rarity  ItemRarity @default(COMMON)
  isMagic Boolean    @default(false)
  tags    String[] // free-text labels for search/homebrew: "silvered", "quest", ...

  // Inherent property of the item definition. Whether a given owner is actually
  // attuned is per-instance (InventoryItem.attuned); 5e caps attunement at 3 per
  // creature — enforce that cap in the service layer.
  requiresAttunement Boolean @default(false)

  // Physical
  weight     Float? // pounds; null = negligible / none
  stackable  Boolean @default(false) // arrows/rations stack; a suit of plate does not
  consumable Boolean @default(false) // potions, scrolls, rations

  // Economy — a flexible REFERENCE value only, stored in COPPER (the atomic 5e
  // coin) as an integer: no float drift, and any coin combination is
  // representable (1 gp = 100 cp). The economy layer to come sits on top of this
  // — shop buy/sell modifiers, supply/demand, per-region and per-merchant
  // pricing, currency conversion. null = unpriced / priceless / quest item.
  baseValueCp Int?

  // Type-specific stat blocks live in their own 1:1 satellite tables instead of
  // as nullable columns here — a WEAPON has a WeaponStats row, ARMOR has an
  // ArmorStats row, everything else has neither. This keeps the base row lean
  // (no sea of nulls), lets each stat be NOT NULL where it belongs, and makes
  // the "type ⟺ stat block" pairing the service layer's invariant to enforce
  // (same discipline as ability-score ranges / the attunement cap). Add further
  // satellites the same way (e.g. ContainerStats) rather than widening Item.
  weapon WeaponStats?
  armor  ArmorStats?

  inventory InventoryItem[]

  @@index([type])
  @@index([rarity])
}

// Weapon-only stats. Exactly one row per WEAPON-typed Item (1:1 on itemId).
// Cascades with its parent Item so deleting the catalog entry drops the stats.
model WeaponStats {
  itemId String @id @db.Uuid
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  weaponCategory   WeaponCategory
  damageDice       String // "1d8" (free text keeps homebrew open)
  damageType       DamageType
  versatileDamage  String? // two-handed damage for versatile weapons, e.g. "1d10"
  weaponProperties WeaponProperty[]
  rangeNormal      Int? // feet (thrown/ranged)
  rangeLong        Int? // feet
}

// Armor-only stats (includes shields via ArmorCategory.SHIELD). Exactly one row
// per ARMOR-typed Item (1:1 on itemId). Cascades with its parent Item.
model ArmorStats {
  itemId String @id @db.Uuid
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  armorCategory       ArmorCategory
  baseArmorClass      Int // for a shield, store the bonus (e.g. 2); interpret by category in the service layer
  addDexToArmorClass  Boolean       @default(false) // light/medium armor add Dex mod
  maxDexBonus         Int? // medium armor caps at +2; null = uncapped
  strengthRequirement Int? // heavy armor STR minimum
  stealthDisadvantage Boolean       @default(false)
}

// One catalog Item assigned to one owner, with per-instance inventory state.
// Multiple rows for the same itemId = the same item held by different owners
// (or separate stacks held by the same owner). Exactly one owner FK should be
// set — enforce in the service layer (and via a CHECK constraint in the migration).
model InventoryItem {
  id     String @id @default(uuid()) @db.Uuid
  itemId String @db.Uuid
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  // Owner — polymorphic via nullable FKs. Add shopId/chestId here later.
  characterId String?          @db.Uuid
  character   PlayerCharacter? @relation(fields: [characterId], references: [id], onDelete: Cascade)
  creatureId  String?          @db.Uuid
  creature    Creature?        @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  // Per-instance state
  quantity Int     @default(1)
  equipped Boolean @default(false)
  attuned  Boolean @default(false)

  @@index([itemId])
  @@index([characterId])
  @@index([creatureId])
}

// ---------------------------------------------------------------------------
// Creature — the reusable NPC / Monster profile.
// NPCs and monsters share an identical 5e stat block, so they are one table
// discriminated by `kind`; NPC-only and Monster-only fields sit alongside as
// nullable columns. Mirrors PlayerCharacter conventions: `@db.SmallInt` ability
// scores (final values), six save-proficiency booleans, createdAt/updatedAt.
//
// Derived-not-stored discipline (same as PlayerCharacter): proficiency bonus
// (from CR), save/skill bonuses (ability mod + prof), passive Perception, and
// spell math are computed in the service layer, never columns here.
// ---------------------------------------------------------------------------
model Creature {
  id   String       @id @default(uuid()) @db.Uuid
  kind CreatureKind // NPC | MONSTER — discriminator

  name        String
  description String?

  // Header
  size          CreatureSize  @default(MEDIUM)
  creatureType  CreatureType? // aberration, beast, ... (5e type)
  typeTags      String[] // free-text subtypes: "goblinoid", "shapechanger"
  alignment     Alignment?
  alignmentNote String? // "unaligned", "any evil alignment" — beyond the enum

  // Defense
  armorClass     Int
  armorClassNote String? // "natural armor", "18 with mage armor"
  hitPoints      Int // average HP
  hitDice        String? // "18d10 + 36"

  // Movement (feet). null = the creature lacks that mode.
  speed       Int     @default(30)
  flySpeed    Int?
  swimSpeed   Int?
  climbSpeed  Int?
  burrowSpeed Int?
  hover       Boolean @default(false)

  // Ability scores (final values)
  strength     Int @db.SmallInt
  dexterity    Int @db.SmallInt
  constitution Int @db.SmallInt
  intelligence Int @db.SmallInt
  wisdom       Int @db.SmallInt
  charisma     Int @db.SmallInt

  // Saving-throw proficiencies (the +N bonus is derived, not stored)
  strengthSaveProf     Boolean @default(false)
  dexteritySaveProf    Boolean @default(false)
  constitutionSaveProf Boolean @default(false)
  intelligenceSaveProf Boolean @default(false)
  wisdomSaveProf       Boolean @default(false)
  charismaSaveProf     Boolean @default(false)

  // Senses (range in feet; null = absent). Passive Perception is derived.
  darkvision  Int?
  blindsight  Int?
  blindBeyond Boolean @default(false) // "blind beyond this radius"
  tremorsense Int?
  truesight   Int?

  // Languages (free-text: "Common, Draconic", "understands Abyssal", "—") and
  // condition immunities (free-text to match CharacterCondition.name).
  languages           String?
  conditionImmunities String[]

  // Challenge. CR is exact for 1/8, 1/4, 1/2 and integers to 30; XP is stored
  // as the block prints it. Proficiency bonus is derived from CR, not stored.
  challengeRating  Decimal? @db.Decimal(5, 3)
  experiencePoints Int?

  // Legendary / lair
  legendaryActionsPerRound Int? // usually 3
  hasLair                  Boolean @default(false)

  // Monster-only flavor (nullable)
  environment String[] // habitats: "Forest", "Underdark"
  source      String? // "Monster Manual", homebrew doc, ...

  // NPC-only flavor (nullable)
  occupation String? // "Blacksmith", "Guard Captain"
  faction    String?
  race       String?

  // Relations
  entries         StatBlockEntry[]
  skills          CreatureSkill[]
  damageModifiers CreatureDamageModifier[]
  inventory       InventoryItem[]
  placements      CreaturePlacement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
  @@index([creatureType])
}

// A single stat-block section (trait / action / legendary action / ...).
// One polymorphic table keyed by `category` instead of a table per section.
model StatBlockEntry {
  id         String   @id @default(uuid()) @db.Uuid
  creatureId String   @db.Uuid
  creature   Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  category    StatBlockEntryCategory
  name        String // "Multiattack", "Bite", "Legendary Resistance"
  description String // free-text MM prose (to-hit, damage, effects)

  sortOrder     Int  @default(0) // preserve MM ordering within a category
  legendaryCost Int? // "Costs 2 Actions" for legendary actions

  @@index([creatureId])
}

// A skill proficiency held by a creature. Mirrors CharacterSkill; the +N bonus
// is derived (ability mod + prof, doubled for EXPERTISE).
model CreatureSkill {
  id         String   @id @default(uuid()) @db.Uuid
  creatureId String   @db.Uuid
  creature   Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  skill       Skill
  proficiency SkillProficiency @default(PROFICIENT)

  @@unique([creatureId, skill])
}

// Damage vulnerability / resistance / immunity. `note` carries the qualifier
// ("from nonmagical attacks not made with silvered weapons"); `damageType` may
// be null for a purely descriptive line.
model CreatureDamageModifier {
  id         String   @id @default(uuid()) @db.Uuid
  creatureId String   @db.Uuid
  creature   Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  kind       DamageModifierKind
  damageType DamageType?
  note       String?

  @@index([creatureId])
}

// ---------------------------------------------------------------------------
// Explicit join model for the Creature <-> Location many-to-many.
// Unlike an implicit relation, it lets each assignment carry its own fields
// (quantity, notes, spawn rate, etc.).
// ---------------------------------------------------------------------------
model CreaturePlacement {
  creatureId String @db.Uuid
  locationId String @db.Uuid

  creature Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  quantity Int     @default(1) // how many appear at this location
  notes    String? // per-location detail, e.g. "runs the north-gate armory"

  @@id([creatureId, locationId])
}

// ---------------------------------------------------------------------------
// Spells, feats, features, and conditions. Catalog rows (Spell/Feat/Feature)
// are shared definitions; the join models attach them to a character with the
// per-character state that D&D tracks (prepared/known, active condition, etc.).
// ---------------------------------------------------------------------------
model Spell {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  level       Int // 0 = cantrip
  school      SpellSchool?
  description String?

  // Casting details — free text keeps homebrew open.
  castingTime String? // "1 action", "1 bonus action", "1 minute"
  range       String? // "60 feet", "Self", "Touch"
  duration    String? // "Instantaneous", "Concentration, up to 1 minute"
  higherLevel String? // "At Higher Levels" scaling text

  // Components (V/S/M). `materialComponent` holds the material text when material.
  verbal            Boolean @default(false)
  somatic           Boolean @default(false)
  material          Boolean @default(false)
  materialComponent String? // "a tiny ball of bat guano and sulfur"

  concentration Boolean @default(false)
  ritual        Boolean @default(false)

  // Structured combat hooks for the future derived/combat layer. Null when the
  // spell forces no save / deals no typed damage; `isAttack` flags spell attacks.
  savingThrow Ability?
  damageType  DamageType?
  isAttack    Boolean     @default(false)

  characters CharacterSpell[]
}

model CharacterSpell {
  characterId String          @db.Uuid
  spellId     String          @db.Uuid
  character   PlayerCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  spell       Spell           @relation(fields: [spellId], references: [id], onDelete: Cascade)

  known          Boolean @default(true)
  prepared       Boolean @default(false)
  // Domain/oath/subclass spells that are always prepared and do not count
  // against the caster's prepared-spell limit.
  alwaysPrepared Boolean @default(false)
  sourceClass    String? // which class granted it (multiclass casters)

  @@id([characterId, spellId])
}

model Feat {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String?

  prerequisite String? // "Strength 13 or higher", "Ability to cast a spell"
  repeatable   Boolean @default(false) // can be taken more than once

  // Half-feats grant a +1 ability score increase alongside their benefit.
  grantsAbilityScoreIncrease Boolean @default(false)

  characters CharacterFeat[]
}

model CharacterFeat {
  characterId String          @db.Uuid
  featId      String          @db.Uuid
  character   PlayerCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  feat        Feat            @relation(fields: [featId], references: [id], onDelete: Cascade)

  @@id([characterId, featId])
}

// Generalized features/traits: class features (Sneak Attack), subclass
// features, racial traits (Darkvision), background features. `source` tags the
// origin. Feats also fit here (source = FEAT) but keep their own catalog above.
model Feature {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  description String?
  source      FeatureSource

  level   Int? // class level the feature is gained at; null for racial/background
  subtype String? // free-text origin detail: "Wizard", "School of Evocation", "Elf"

  characters CharacterFeature[]

  @@unique([name, source])
}

model CharacterFeature {
  characterId String          @db.Uuid
  featureId   String          @db.Uuid
  character   PlayerCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  feature     Feature         @relation(fields: [featureId], references: [id], onDelete: Cascade)

  notes String? // per-character detail, e.g. a chosen option

  @@id([characterId, featureId])
}

// Active status effects (poisoned, prone, ...). Free-text name keeps homebrew open.
model CharacterCondition {
  id          String          @id @default(uuid()) @db.Uuid
  characterId String          @db.Uuid
  character   PlayerCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  name  String // "poisoned", "prone", "exhaustion"
  level Int? // for stacking conditions like exhaustion
  notes String?

  @@unique([characterId, name])
}
