DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dungeons_and_data?schema=public"
PORT=3000

# Auth. JWT_SECRET is REQUIRED (the app fails fast if unset). JWT_EXPIRES_IN is
# optional and accepts any `jsonwebtoken` expiresIn value (default "7d").
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Seed bootstrap for the first Admin account (used by prisma/seed.ts).
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# CORS. Unset = allow any origin (fine for a Bearer-token API in dev). Set to a
# comma-separated list of allowed origins to restrict it, e.g.
# CORS_ORIGIN="http://localhost:5173,https://app.example.com"
CORS_ORIGIN=""
